### variables
@baseUrl = http://localhost:3000/api/v1
@contentType = application/json

#------------------------------------
# basic requests
# @name getAllTasks
GET {{baseUrl}}/tasks
###
# @name getAllWithSearchQuery
GET {{baseUrl}}/tasks?search=Nest

###
# @name getAllWithFilteredByLabel
GET {{baseUrl}}/tasks?labels=wow

###
# @name getAllSorted
GET {{baseUrl}}/tasks?sortBy=createdAt&sortOrder=DESC
### Create task
# @name createTask
POST {{baseUrl}}/tasks
Content-Type: {{contentType}}

{
    "title": "Learn nest js",
    "description": "Learn how to use nest js framework for building scalable server-side applications",
    "userId":"1d71ce28-0c12-4865-97c9-2c190da6eb04"
    ,"labels":[{"name":"Nice"},{"name":"wow"},{"name":"wasmt expecting"}]
}

### Set the task id
@taskId = {{createTask.response.body.id}}
###

### find task by id
# @name findTaskById
GET {{baseUrl}}/tasks/{{taskId}}


### update task status
# @name updateTaskStatus
PATCH {{baseUrl}}/tasks/{{taskId}}/status
Content-Type: {{contentType}}

{
    "status": "IN_PROGRESS"

}

### update task
# @name updateTask
PATCH {{baseUrl}}/tasks/{{taskId}}
Content-Type: {{contentType}}

{
    "title": "Learn nest js - updated",
    "description": "Learn how to use nest js framework for building scalable server-side applications - updated"
}



### delete task
# @name deleteTask
DELETE {{baseUrl}}/tasks/{{taskId}}

### add specific labels to tasks
# @name addLabels
POST {{baseUrl}}/tasks/{{taskId}}/labels
Content-Type: {{contentType}}

[
    {"name":"backend"},
    {"name":"ja1"}
 ]


### remove specific labels to tasks
# @name removeLabels
DELETE  {{baseUrl}}/tasks/{{taskId}}/labels
Content-Type: {{contentType}}

[
  "backend",
    "ja1"
 ]
